# Keep the Docker build context small to speed up builds. This is really all we need in the Dockerfile.

*
!webapp
!migrations
!.flaskenv
!pyproject.toml
!uv.lock

# Only ship the data directory structure (the .gitignore placeholders), not the large local
# runtime data (debug dumps, downloaded geopackage, imported images), which is mounted at runtime.
!data/**/.gitignore
