# syntax=docker/dockerfile:1

FROM python:3.12-alpine3.21

# Bring in the uv binary from the official, pinned image (kept up to date by dependabot).
COPY --from=ghcr.io/astral-sh/uv:0.11.18 /uv /uvx /bin/

RUN apk update && \
    apk upgrade && \
    apk add bash geos

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# In docker-compose the project root is bind-mounted over /app for live code reloading. That mount
# would shadow a virtualenv created inside /app, so we put the environment in /opt/venv instead and
# add it to PATH. This way `python`, `flask`, `ruff`, `pytest`, ... all resolve to the venv.
ENV UV_PROJECT_ENVIRONMENT=/opt/venv
ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy
ENV PATH="/opt/venv/bin:$PATH"

WORKDIR /app

# Install all dependencies (including the dev dependency group) from the lockfile. Build tools are
# only needed to compile wheels and are removed afterwards to keep the image small.
COPY pyproject.toml uv.lock ./
RUN apk add --no-cache --virtual .build-deps geos-dev alpine-sdk && \
    uv sync --frozen && \
    apk del .build-deps

EXPOSE 5000
